#version 430 core

struct PGTO {
    float coeff;
    float alpha;
    uint ijkl;
};

struct CGTO {
    vec3 center;
    uvec2 pgto_range; // beg + end
};

layout (binding = 0, std430) readonly restrict buffer CGTO_XYZR_BUFFER {
    vec4 cgto_xyzr[];
};
layout (binding = 1, std430) readonly restrict buffer CGTO_OFFSET_BUFFER {
    uvec2 cgto_off_len[];
};
layout (binding = 2, std430) readonly restrict buffer PGTO_BUFFER {
    PGTO pgto[];
};
layout (binding = 3, std430) readonly restrict buffer D_BUFFER {
    float D_matrix[];
};

layout(std140, binding = 0) uniform UniformBlock {
    mat4 world_to_model;
    mat4 index_to_world;
    vec4 step;
    uint D_matrix_dim;
    uint operation;
};

layout(binding = 0, r32f) uniform image3D vol;

#define OP_SET 0u
#define OP_ADD 1u
#define OP_SUB 2u
#define OP_MAX 3u
#define OP_MIN 4u
#define OP_ACCUM_MASK 0x0000000Fu
#define OP_ABS 0x00000100u

uvec4 unpack_ijkl(in uint ijkl) {
    return uvec4(
        (ijkl >>  0) & 0xFFu,
        (ijkl >>  8) & 0xFFu,
        (ijkl >> 16) & 0xFFu,
        (ijkl >> 24) & 0xFFu
    );
}

#define WG_X 8
#define WG_Y 8
#define WG_Z 8

#define WG_SIZE (WG_X * WG_Y * WG_Z)
#define TILE_SIZE 16
#define TILE_AREA (TILE_SIZE*TILE_SIZE)
#define MAX_SCREENED_CGTOS 2048
#define MAX_TILE_PGTOS (TILE_SIZE * 32)
#define INVALID_CGTO_IDX 0xFFFFFFFFu

shared uint  screened_cgtos[MAX_SCREENED_CGTOS];
shared uint  num_screened_cgtos;

shared float D_tile[TILE_SIZE][TILE_SIZE];
shared CGTO  cgtos_tile[TILE_SIZE];
shared PGTO  pgtos_tile[MAX_TILE_PGTOS];
shared uint  num_pgtos;

// Per-CGTO source ranges written by phase 1 of fill_cgtos_tile,
// read by all threads in phase 2.
shared uvec2 gs_src_off_len[TILE_SIZE];

// Calculates the D matrix index for the upper triangular symmetric matrix storage
uint get_index(uint i, uint j, uint N) {
    uint row = (i < j) ? i : j;   // smaller index
    uint col = (i < j) ? j : i;   // larger index
    uint row_offset = row * (2 * N - row + 1) / 2;
    return row_offset + (col - row);
}

// Full D_tile from global D_matrix
void fill_D_tile(uint tile_i, uint tile_j) {
    const uint tid  = gl_LocalInvocationIndex;

    uint baseI = tile_i * TILE_SIZE;
    uint baseJ = tile_j * TILE_SIZE;

    for (uint index = tid; index < TILE_AREA; index += WG_SIZE) {
        uint row = index / TILE_SIZE;
        uint col = index % TILE_SIZE;

        uint idxI = baseI + row;
        uint gi = (idxI < num_screened_cgtos) ? screened_cgtos[idxI] : INVALID_CGTO_IDX;

        uint idxJ = baseJ + col;
        uint gj = (idxJ < num_screened_cgtos) ? screened_cgtos[idxJ] : INVALID_CGTO_IDX;

        float value = 0.0;
        if (gi != INVALID_CGTO_IDX && gj != INVALID_CGTO_IDX) {
            value = D_matrix[get_index(gi, gj, D_matrix_dim)];
        }
        D_tile[row][col] = value;
    }
}

// Two-phase CGTO/PGTO loader that utilises all WG_SIZE threads.
//
// Phase 1 (threads 0 .. TILE_SIZE-1):
//   Read CGTO metadata, atomically reserve pgtos_tile slots, write
//   cgtos_tile[] headers and gs_src_off_len[].
//
// [barrier]
//
// Phase 2 (all WG_SIZE threads):
//   Cooperatively copy every PGTO belonging to this tile from the
//   global buffers into pgtos_tile using a strided loop.
void fill_cgtos_tile(uint tile_number) {
    const uint tid = gl_LocalInvocationIndex;

    // --- Phase 1: metadata gather (TILE_SIZE threads) ---
    if (tid < TILE_SIZE) {
        uint slot = tile_number * TILE_SIZE + tid;
        uint global_cgto_idx = (slot < num_screened_cgtos) ? screened_cgtos[slot] : INVALID_CGTO_IDX;

        vec3  cgto_center = vec3(0.0);
        uvec2 off_len     = uvec2(0u, 0u);
        uint  dst         = 0u;

        if (global_cgto_idx != INVALID_CGTO_IDX) {
            off_len = cgto_off_len[global_cgto_idx];
            cgto_center = cgto_xyzr[global_cgto_idx].xyz;
            dst = atomicAdd(num_pgtos, off_len.y);
        }

        gs_src_off_len[tid]        = off_len;
        cgtos_tile[tid].center     = cgto_center;
        cgtos_tile[tid].pgto_range = uvec2(dst, dst + off_len.y);
    }

    // Ensure metadata is visible to all threads before phase 2.
    barrier();

    // --- Phase 2: cooperative PGTO load (all WG_SIZE threads) ---
    for (uint ci = 0u; ci < TILE_SIZE; ci++) {
        uvec2 off_len = gs_src_off_len[ci];
        uint src = off_len.x;
        uint len = off_len.y;
        uint dst = cgtos_tile[ci].pgto_range.x;
        for (uint k = tid; k < len; k += WG_SIZE) {
            pgtos_tile[dst + k] = pgto[src + k];
        }
    }
}

void eval_phis(out float out_phi[TILE_SIZE], vec3 coord) {
    for (uint i = 0; i < TILE_SIZE; ++i) {
        uvec2 pgto_range = cgtos_tile[i].pgto_range;

        vec3 center = cgtos_tile[i].center;
        vec3 d   = coord - center;
        float r2 = dot(d, d);

        float dx2 = d.x * d.x;
        float dy2 = d.y * d.y;
        float dz2 = d.z * d.z;

        float phi = 0.0;
        for (uint j = pgto_range.x; j < pgto_range.y; ++j) {
            PGTO p = pgtos_tile[j];
            uvec4 ijkl = unpack_ijkl(p.ijkl);
            float fx = (ijkl.x == 0u) ? 1.0 :
                       (ijkl.x == 1u) ? d.x :
                       (ijkl.x == 2u) ? dx2 :
                       (ijkl.x == 3u) ? dx2 * d.x : dx2 * dx2;

            float fy = (ijkl.y == 0u) ? 1.0 :
                       (ijkl.y == 1u) ? d.y :
                       (ijkl.y == 2u) ? dy2 :
                       (ijkl.y == 3u) ? dy2 * d.y : dy2 * dy2;

            float fz = (ijkl.z == 0u) ? 1.0 :
                       (ijkl.z == 1u) ? d.z :
                       (ijkl.z == 2u) ? dz2 :
                       (ijkl.z == 3u) ? dz2 * d.z : dz2 * dz2;

            phi += p.coeff * fx * fy * fz * exp(-p.alpha * r2);
        }
        out_phi[i] = phi;
    }
}

float symmetric_contraction(float phi[TILE_SIZE]) {
    float result = 0.0;
    for (uint i = 0; i < TILE_SIZE; ++i) {
        float ai = phi[i];
        result = fma(D_tile[i][i] * ai, ai, result);
        ai = 2.0 * ai;
        for (uint j = i + 1; j < TILE_SIZE; ++j) {
            result = fma(D_tile[i][j] * ai, phi[j], result);
        }
    }
    return result;
}

float contraction(float phi_mu[TILE_SIZE], float phi_nu[TILE_SIZE]) {
    float result = 0.0;
    for (uint i = 0; i < TILE_SIZE; ++i) {
        float ai = 2.0 * phi_mu[i];
        for (uint j = 0; j < TILE_SIZE; ++j) {
            result = fma(D_tile[i][j] * ai, phi_nu[j], result);
        }
    }
    return result;
}

layout (local_size_x = WG_X, local_size_y = WG_Y, local_size_z = WG_Z) in;
void main() {
    uint tid = gl_LocalInvocationIndex;
    if (tid == 0) {
        num_screened_cgtos = 0;
    }
    barrier();

    vec3 model_aabb_min = vec3( gl_WorkGroupID.xyz                 * gl_WorkGroupSize.xyz) * step.xyz;
    vec3 model_aabb_max = vec3((gl_WorkGroupID.xyz + uvec3(1,1,1)) * gl_WorkGroupSize.xyz) * step.xyz;
    // Stage 1: Screening. Prune CGTOs to identify which are relevant for region
    {
        for (uint i = tid; i < D_matrix_dim; i += WG_SIZE) {
            vec4 cgto = cgto_xyzr[i];
            if (cgto.w == 0.0) continue;

            vec3 model_xyz = vec3(world_to_model * vec4(cgto.xyz, 1.0));
            float r2       = cgto.w * cgto.w;

            vec3   d = clamp(model_xyz, model_aabb_min, model_aabb_max) - model_xyz;
            float d2 = dot(d, d);

            if (d2 < r2) {
                uint idx = atomicAdd(num_screened_cgtos, 1u);
                if (idx < MAX_SCREENED_CGTOS) {
                    screened_cgtos[idx] = i;
                }
            }
        }

        barrier();

        // Clamp to capacity
        if (tid == 0) {
            if (num_screened_cgtos > MAX_SCREENED_CGTOS) {
                num_screened_cgtos = MAX_SCREENED_CGTOS;
            }
        }
        barrier();

    }

    float phi_tile_mu[TILE_SIZE]; // evaluated φ_μ(r) in registers
    float phi_tile_nu[TILE_SIZE]; // evaluated φ_ν(r) in registers
    vec3 coord = (index_to_world * vec4(gl_GlobalInvocationID.xyz, 1.0)).xyz;
    float rho = 0.0;

    if (num_screened_cgtos > 0u) {
        // DIV UP
        uint num_tiles = (num_screened_cgtos + TILE_SIZE - 1) / TILE_SIZE;

        for (uint tile_i = 0; tile_i < num_tiles; ++tile_i) {
            // DIAGONAL TILE

            if (tid == 0) {
                num_pgtos = 0;
            }
            barrier();

            // Populate GSM
            fill_D_tile(tile_i, tile_i);
            fill_cgtos_tile(tile_i);

            barrier();

            // Evaluate into phi mu
            eval_phis(phi_tile_mu, coord);

            // Diagonal tile Contribution
            rho += symmetric_contraction(phi_tile_mu);

            for (uint tile_j = tile_i + 1; tile_j < num_tiles; ++tile_j) {
                // OFF DIAGONAL TILE
                if (tid == 0) {
                    num_pgtos = 0;
                }

                barrier();

                // Populate GSM
                fill_D_tile(tile_i, tile_j);
                fill_cgtos_tile(tile_j);

                barrier();

                // Evaluate into phi nu
                eval_phis(phi_tile_nu, coord);

                // Off-diagonal tile Contribution
                rho += contraction(phi_tile_mu, phi_tile_nu);
            }
        }
    }
    
    // Step 3: Write result
    if (all(lessThan(gl_GlobalInvocationID.xyz, imageSize(vol)))) {
        ivec3 vol_idx = ivec3(gl_GlobalInvocationID.xyz);
        if ((operation & OP_ABS) != 0u) {
            rho = abs(rho);
        }

        switch (operation & OP_ACCUM_MASK) {
        case OP_SET:
            break;
        case OP_ADD:
            rho += imageLoad(vol, vol_idx).x;
            break;
        case OP_SUB:
            rho = imageLoad(vol, vol_idx).x - rho;
            break;
        case OP_MAX:
            rho = max(rho, imageLoad(vol, vol_idx).x);
            break;
        case OP_MIN:
            rho = min(rho, imageLoad(vol, vol_idx).x);
            break;
        default:
            break;
        }

        imageStore(vol, vol_idx, vec4(rho));
    }
}